# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxxx

# Боты
PLATFORM_BOT_TOKEN=токен_бота_платформы
OWNER_TELEGRAM_ID=твой_telegram_id

# Шифрование токенов (ровно 32 символа, случайная строка)
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL сервера (нужен для настройки webhook ботов мастеров)
VPS_URL=https://твой-домен.ru

# URL фронтенда (для кнопки меню в боте)
FRONTEND_URL=https://tg-beauty-catalog-ebon.vercel.app

# CORS
ALLOWED_ORIGIN=https://tg-beauty-catalog-ebon.vercel.app

# ЮKassa (получить на yookassa.ru → Настройки → API)
YUKASSA_SHOP_ID=ваш_shop_id
YUKASSA_SECRET_KEY=ваш_секретный_ключ

# Порт сервера
PORT=3000
